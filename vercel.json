{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd suqaist && npm install && npm run build",
  "outputDirectory": "suqaist/.next",
  "installCommand": "cd suqaist && npm install",
  "crons": [
    {
      "path": "/api/cron/prices",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/news",
      "schedule": "0 11 * * *"
    }
  ]
}
